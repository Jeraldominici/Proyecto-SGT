@model List<TransporteEscolar.Models.Autobus>
@{
    ViewData["Title"] = "Gestión de Autobuses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; justify-content:space-between; align-items:center;
            margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
    <div>
        <a asp-action="Dashboard" asp-controller="Admin"
           style="display:inline-flex; align-items:center; gap:.4rem; margin-bottom:1.25rem;
          font-size:.875rem; font-weight:600; color:#64748B; text-decoration:none;
          padding:.4rem .85rem; border:1.5px solid #E2E8F0; border-radius:8px;
          background:#fff; transition:.15s;"
           onmouseover="this.style.borderColor='#2563EB'; this.style.color='#2563EB';"
           onmouseout="this.style.borderColor='#E2E8F0'; this.style.color='#64748B';">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                 style="width:15px; height:15px;">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
            </svg>
            Volver al Dashboard
        </a>
        <h2 style="font-size:1.375rem; font-weight:700; color:#0F172A; margin:0;">
            Gestión de Autobuses
        </h2>
        <p style="color:#64748B; font-size:.875rem; margin-top:.2rem;">
            @Model.Count autobús(es) registrado(s) —
            @Model.Count(a => a.Activo) activo(s)
        </p>
    </div>
    <a asp-action="Crear" asp-controller="Autobus" class="btn-primary-action">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
             style="width:16px;height:16px;">
            <path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z" />
        </svg>
        Nuevo Autobús
    </a>
</div>
<div style="position:relative; max-width:320px; margin-bottom:1rem;">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
         style="position:absolute; left:.75rem; top:50%; transform:translateY(-50%);
                width:16px; height:16px; color:#94A3B8; pointer-events:none;">
        <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
    </svg>
    <input type="text" id="buscarAutobuses" placeholder="Buscar autobús..."
           style="width:100%; padding:.6rem .9rem .6rem 2.25rem; border:1.5px solid #E2E8F0;
                  border-radius:8px; font-size:.875rem; font-family:'Inter',sans-serif;
                  color:#0F172A; outline:none; transition:.15s; box-sizing:border-box;"
           onfocus="this.style.borderColor='#2563EB'; this.style.boxShadow='0 0 0 3px rgba(37,99,235,.1)';"
           onblur="this.style.borderColor='#E2E8F0'; this.style.boxShadow='none';" />
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert-toast success">✅ @TempData["Exito"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-toast error">❌ @TempData["Error"]</div>
}

@* Tarjetas resumen *@
<div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr));
            gap:1rem; margin-bottom:1.75rem;">
    <div class="stat-card">
        <div class="stat-icon" style="background:#EFF6FF; color:#2563EB;">🚌</div>
        <div class="stat-value">@Model.Count</div>
        <div class="stat-label">Total</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#F0FDF4; color:#15803D;">✅</div>
        <div class="stat-value">@Model.Count(a => a.Activo)</div>
        <div class="stat-label">Activos</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#FEF2F2; color:#DC2626;">⛔</div>
        <div class="stat-value">@Model.Count(a => !a.Activo)</div>
        <div class="stat-label">Inactivos</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:#FEF3C7; color:#D97706;">👥</div>
        <div class="stat-value">@Model.Sum(a => a.Usuarios.Count)</div>
        <div class="stat-label">Azafatas asignadas</div>
    </div>
</div>

<div class="tabla-card">
    <table class="tabla-usuarios" id="tablaAutobuses">
        <thead>
            <tr>
                <th>Ficha</th>
                <th>Placa</th>
                <th>Capacidad</th>
                <th>Azafatas</th>
                <th>Estado</th>
                <th>Fecha de Alta</th>
                <th style="text-align:center;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var bus in Model)
            {
                <tr class="@(!bus.Activo ? "row-bloqueado" : "")">
                    <td>
                        <div style="display:flex; align-items:center; gap:.65rem;">
                            <div class="bus-icon">🚌</div>
                            <span style="font-weight:700; color:#0F172A; font-size:.9375rem;">
                                @bus.Ficha
                            </span>
                        </div>
                    </td>
                    <td style="font-weight:500; color:#334155;">@bus.Placa</td>
                    <td>
                        <div style="display:flex; align-items:center; gap:.4rem;">
                            <div class="capacidad-bar-wrap">
                                <div class="capacidad-bar"
                                     style="width:@(Math.Min(bus.Capacidad, 100))%">
                                </div>
                            </div>
                            <span style="font-size:.8125rem; color:#64748B;">
                                @bus.Capacidad pasajeros
                            </span>
                        </div>
                    </td>
                    <td>
                        @if (bus.Usuarios.Any())
                        {
                            <div style="display:flex; flex-wrap:wrap; gap:.3rem;">
                                @foreach (var u in bus.Usuarios.Take(3))
                                {
                                    <span class="mini-tag">@u.NombreCompleto.Split(' ')[0]</span>
                                }
                                @if (bus.Usuarios.Count > 3)
                                {
                                    <span class="mini-tag">+@(bus.Usuarios.Count - 3)</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color:#94A3B8; font-size:.8125rem;">Sin asignar</span>
                        }
                    </td>
                    <td>
                        @if (bus.Activo)
                        {
                            <span class="status-badge activo">● Activo</span>
                        }
                        else
                        {
                            <span class="status-badge inactivo">● Inactivo</span>
                        }
                    </td>
                    <td style="color:#64748B; font-size:.8125rem;">
                        @bus.FechaAlta.ToLocalTime().ToString("dd/MM/yyyy")
                    </td>
                    <td>
                        <div class="acciones-cell">
                            <a asp-action="Editar" asp-controller="Autobus"
                               asp-route-id="@bus.AutobusId"
                               class="btn-accion editar" title="Editar">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z" />
                                    <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0010 3H4.75A2.75 2.75 0 002 5.75v9.5A2.75 2.75 0 004.75 18h9.5A2.75 2.75 0 0017 15.25V10a.75.75 0 00-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5z" />
                                </svg>
                            </a>

                            <form asp-action="ToggleActivo" asp-controller="Autobus"
                                  asp-route-id="@bus.AutobusId"
                                  method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn-accion @(bus.Activo ? "bloquear" : "desbloquear")"
                                        title="@(bus.Activo ? "Desactivar" : "Activar")">
                                    @if (bus.Activo)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M14.5 1A4.5 4.5 0 0010 5.5V9H3a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-1.5V5.5a3 3 0 116 0v2.75a.75.75 0 001.5 0V5.5A4.5 4.5 0 0014.5 1z" clip-rule="evenodd" />
                                        </svg>
                                    }
                                </button>
                            </form>

                            <form asp-action="Eliminar" asp-controller="Autobus"
                                  asp-route-id="@bus.AutobusId"
                                  method="post" style="display:inline;"
                                  onsubmit="return confirm('¿Eliminar el autobús @bus.Ficha? Esta acción no se puede deshacer.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-accion eliminar" title="Eliminar">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    document.getElementById('buscarAutobuses').addEventListener('input', function () {
        const texto = this.value.toLowerCase().trim();
        document.querySelectorAll('#tablaAutobuses tbody tr').forEach(function (fila) {
            fila.style.display = fila.textContent.toLowerCase().includes(texto) ? '' : 'none';
        });
    });
</script>

<style>
    .btn-primary-action {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .55rem 1.1rem;
        background: #2563EB;
        color: #fff;
        border-radius: 8px;
        font-size: .875rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .18s ease;
    }

        .btn-primary-action:hover {
            background: #1D4ED8;
            transform: translateY(-1px);
        }

    .alert-toast {
        padding: .75rem 1.1rem;
        border-radius: 8px;
        font-size: .875rem;
        font-weight: 500;
        margin-bottom: 1.25rem;
    }

        .alert-toast.success {
            background: #F0FDF4;
            color: #166534;
            border: 1px solid #BBF7D0;
        }

        .alert-toast.error {
            background: #FEF2F2;
            color: #991B1B;
            border: 1px solid #FECACA;
        }

    .stat-card {
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 12px;
        padding: 1.1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: .4rem;
    }

    .stat-icon {
        font-size: 1.4rem;
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0F172A;
    }

    .stat-label {
        font-size: .75rem;
        color: #64748B;
        font-weight: 500;
    }

    .tabla-card {
        background: #fff;
        border-radius: 12px;
        border: 1.5px solid #E2E8F0;
        overflow-x: auto;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
    }

    .tabla-usuarios {
        width: 100%;
        border-collapse: collapse;
    }

        .tabla-usuarios thead tr {
            background: #F8FAFC;
            border-bottom: 1.5px solid #E2E8F0;
        }

        .tabla-usuarios th {
            padding: .75rem 1rem;
            text-align: left;
            font-size: .75rem;
            font-weight: 700;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: .05em;
            white-space: nowrap;
        }

        .tabla-usuarios td {
            padding: .85rem 1rem;
            font-size: .875rem;
            color: #334155;
            border-bottom: 1px solid #F1F5F9;
            vertical-align: middle;
        }

        .tabla-usuarios tbody tr:hover {
            background: #F8FAFC;
        }

        .tabla-usuarios tbody tr:last-child td {
            border-bottom: none;
        }

    .row-bloqueado {
        opacity: .6;
    }

    .bus-icon {
        width: 34px;
        height: 34px;
        background: #EFF6FF;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .capacidad-bar-wrap {
        width: 60px;
        height: 6px;
        background: #E2E8F0;
        border-radius: 99px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .capacidad-bar {
        height: 100%;
        background: #2563EB;
        border-radius: 99px;
        transition: width .3s ease;
    }

    .mini-tag {
        font-size: .7rem;
        font-weight: 600;
        padding: .15rem .5rem;
        background: #F1F5F9;
        color: #475569;
        border-radius: 20px;
    }

    .status-badge {
        font-size: .75rem;
        font-weight: 600;
        padding: .2rem .65rem;
        border-radius: 20px;
    }

        .status-badge.activo {
            background: #F0FDF4;
            color: #15803D;
        }

        .status-badge.inactivo {
            background: #F8FAFC;
            color: #64748B;
        }

    .acciones-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
    }

    .btn-accion {
        width: 32px;
        height: 32px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: all .15s ease;
        text-decoration: none;
    }

        .btn-accion svg {
            width: 15px;
            height: 15px;
        }

        .btn-accion.editar {
            background: #EFF6FF;
            color: #2563EB;
        }

            .btn-accion.editar:hover {
                background: #2563EB;
                color: #fff;
            }

        .btn-accion.bloquear {
            background: #FEF3C7;
            color: #D97706;
        }

            .btn-accion.bloquear:hover {
                background: #D97706;
                color: #fff;
            }

        .btn-accion.desbloquear {
            background: #F0FDF4;
            color: #15803D;
        }

            .btn-accion.desbloquear:hover {
                background: #15803D;
                color: #fff;
            }

        .btn-accion.eliminar {
            background: #FEF2F2;
            color: #DC2626;
        }

            .btn-accion.eliminar:hover {
                background: #DC2626;
                color: #fff;
            }
</style>