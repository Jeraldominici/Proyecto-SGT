@{
    ViewData["Title"] = "Ruta del Día";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
    <a asp-action="Dashboard" asp-controller="Azafata" class="btn-back">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:16px;height:16px;">
            <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
        </svg>
    </a>
    <div>
        <h2 style="font-size:1.375rem; font-weight:700; color:#0F172A; margin:0;">Ruta del Día</h2>
        <p style="color:#64748B; font-size:.875rem; margin-top:.2rem;">
            @DateTime.Today.ToString("dddd, dd 'de' MMMM",
            new System.Globalization.CultureInfo("es-ES"))
        </p>
    </div>
</div>

<div style="background:#EFF6FF; border:1.5px solid #BFDBFE; border-radius:12px;
            padding:1.25rem; margin-bottom:1.5rem; display:flex; gap:.75rem; align-items:center;">
    <span style="font-size:1.5rem;">🗺️</span>
    <div>
        <div style="font-weight:600; color:#1D4ED8;">Módulo en construcción</div>
        <div style="font-size:.875rem; color:#3B82F6; margin-top:.15rem;">
            La visualización de ruta con mapa se habilitará próximamente.
            Por ahora puedes ver las direcciones de recogida de cada alumno.
        </div>
    </div>
</div>

@{
    var autobusIdRaw = User.FindFirst("AutobusId")?.Value;
}

@if (autobusIdRaw != null)
{
    var autobusId = int.Parse(autobusIdRaw);
}

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">

    <!-- Paradas de Ida -->
    <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:12px; overflow:hidden;">
        <div style="background:linear-gradient(135deg,#FEF3C7,#FDE68A); padding:1rem 1.25rem;
                    border-bottom:1.5px solid #FDE68A;">
            <div style="font-weight:700; color:#92400E; font-size:.9375rem;">🌅 Ruta de Ida</div>
            <div style="font-size:.75rem; color:#B45309; margin-top:.15rem;">Recogida en casa → Escuela</div>
        </div>
        <div style="padding:1rem;">
            <div style="color:#64748B; font-size:.875rem; text-align:center; padding:1.5rem 0;">
                Las paradas se cargarán automáticamente desde las direcciones de recogida de los alumnos.
            </div>
        </div>
    </div>

    <!-- Paradas de Vuelta -->
    <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:12px; overflow:hidden;">
        <div style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE); padding:1rem 1.25rem;
                    border-bottom:1.5px solid #DBEAFE;">
            <div style="font-weight:700; color:#1E40AF; font-size:.9375rem;">🌆 Ruta de Vuelta</div>
            <div style="font-size:.75rem; color:#3B82F6; margin-top:.15rem;">Escuela → Entrega en casa</div>
        </div>
        <div style="padding:1rem;">
            <div style="color:#64748B; font-size:.875rem; text-align:center; padding:1.5rem 0;">
                Las paradas se cargarán automáticamente desde las direcciones de entrega de los alumnos.
            </div>
        </div>
    </div>
</div>

<style>
    .btn-back {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        color: #64748B;
        text-decoration: none;
        transition: all .15s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: #2563EB;
            color: #2563EB;
            background: #EFF6FF;
        }
</style>