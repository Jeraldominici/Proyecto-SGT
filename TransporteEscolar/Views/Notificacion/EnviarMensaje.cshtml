@model TransporteEscolar.ViewModels.MensajeManualViewModel
@{
    ViewData["Title"] = "Enviar Mensaje";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var padres = ViewBag.Padres as List<TransporteEscolar.Models.Usuario> ?? new();
}

<div style="max-width:580px; margin:0 auto;">
    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.75rem;">
        <a asp-action="Dashboard" asp-controller="Admin" class="btn-back">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:16px;height:16px;">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
            </svg>
        </a>
        <div>
            <h2 style="font-size:1.25rem; font-weight:700; color:#0F172A; margin:0;">
                📢 Enviar Mensaje a Padres
            </h2>
            <p style="font-size:.8125rem; color:#64748B; margin-top:.15rem;">
                Las notificaciones aparecerán en el panel de cada padre
            </p>
        </div>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert-toast success" style="margin-bottom:1.25rem;">
            ✅ @TempData["Exito"]
        </div>
    }

    <div style="background:#fff; border:1.5px solid #E2E8F0; border-radius:14px;
                padding:2rem; box-shadow:0 1px 4px rgba(0,0,0,.05);">
        <form asp-action="EnviarMensaje" asp-controller="Notificacion"
              method="post" novalidate>
            @Html.AntiForgeryToken()

            <!-- Título -->
            <div class="fgroup">
                <label asp-for="Titulo" class="flabel">Título</label>
                <input asp-for="Titulo" class="finput"
                       placeholder="ej. Aviso importante sobre el horario" />
                <span asp-validation-for="Titulo" class="ferror"></span>
            </div>

            <!-- Mensaje -->
            <div class="fgroup">
                <label asp-for="Mensaje" class="flabel">Mensaje</label>
                <textarea asp-for="Mensaje" class="finput" rows="4"
                          placeholder="Escribe el mensaje para los padres..."
                          style="resize:vertical;"></textarea>
                <span asp-validation-for="Mensaje" class="ferror"></span>
            </div>

            <!-- Destinatarios -->
            <div class="fgroup">
                <label class="flabel">Destinatarios</label>

                <label style="display:flex; align-items:center; gap:.65rem; padding:.75rem 1rem;
                               border:1.5px solid #E2E8F0; border-radius:9px; cursor:pointer;
                               margin-bottom:.6rem; transition:.15s;"
                       id="lblTodos"
                       onmouseover="this.style.borderColor='#2563EB';"
                       onmouseout="this.style.borderColor=document.getElementById('EnviarATodos').checked?'#2563EB':'#E2E8F0';">
                    <input asp-for="EnviarATodos" type="checkbox" id="EnviarATodos"
                           style="width:16px; height:16px; accent-color:#2563EB;"
                           onchange="togglePadres(this.checked)" />
                    <div>
                        <div style="font-weight:600; font-size:.9rem; color:#0F172A;">
                            Enviar a todos los padres
                        </div>
                        <div style="font-size:.75rem; color:#64748B;">
                            @padres.Count padre(s) registrado(s)
                        </div>
                    </div>
                </label>

                <div id="listaPadres"
                     style="display:@(Model.EnviarATodos ? "none" : "block");
                            border:1.5px solid #E2E8F0; border-radius:9px; overflow:hidden;">
                    @foreach (var p in padres)
                    {
                        <label style="display:flex; align-items:center; gap:.75rem;
                                           padding:.7rem 1rem; cursor:pointer; transition:.15s;
                                           border-bottom:1px solid #F1F5F9;"
                               onmouseover="this.style.background='#F8FAFC';"
                               onmouseout="this.style.background='transparent';">
                            <input type="checkbox" name="UsuariosSeleccionados"
                                   value="@p.UsuarioId"
                                   style="width:15px; height:15px; accent-color:#2563EB;" />
                            <div>
                                <div style="font-weight:500; font-size:.875rem; color:#0F172A;">
                                    @p.NombreCompleto
                                </div>
                                <div style="font-size:.75rem; color:#94A3B8;">@p.NombreUsuario</div>
                            </div>
                        </label>
                    }
                </div>
            </div>

            <!-- Botón -->
            <div style="display:flex; justify-content:flex-end; margin-top:1.5rem;">
                <button type="submit"
                        style="padding:.65rem 1.75rem; background:#7C3AED; color:#fff;
                               border:none; border-radius:8px; font-size:.9rem; font-weight:600;
                               cursor:pointer; font-family:'Inter',sans-serif; transition:.15s;
                               display:flex; align-items:center; gap:.4rem;"
                        onmouseover="this.style.background='#6D28D9';"
                        onmouseout="this.style.background='#7C3AED';">
                    📢 Enviar Notificación
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .fgroup {
        margin-bottom: 1.1rem;
    }

    .flabel {
        display: block;
        font-size: .8125rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .finput {
        width: 100%;
        padding: .65rem .9rem;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        font-size: .9375rem;
        font-family: 'Inter',sans-serif;
        color: #0F172A;
        outline: none;
        transition: .15s;
        box-sizing: border-box;
    }

        .finput:focus {
            border-color: #2563EB;
            box-shadow: 0 0 0 3px rgba(37,99,235,.1);
        }

    .ferror {
        display: block;
        font-size: .8rem;
        color: #DC2626;
        margin-top: .25rem;
        font-weight: 500;
    }

    .btn-back {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 8px;
        color: #64748B;
        text-decoration: none;
        transition: all .15s;
        flex-shrink: 0;
    }

        .btn-back:hover {
            border-color: #2563EB;
            color: #2563EB;
            background: #EFF6FF;
        }

    .alert-toast {
        padding: .75rem 1.1rem;
        border-radius: 8px;
        font-size: .875rem;
        font-weight: 500;
    }

        .alert-toast.success {
            background: #F0FDF4;
            color: #166534;
            border: 1px solid #BBF7D0;
        }
</style>

<script>
    function togglePadres(enviarATodos) {
        document.getElementById('listaPadres').style.display =
            enviarATodos ? 'none' : 'block';
    }
</script>